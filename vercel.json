{
  "version": 2,
  "buildCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!fonts).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "FREEPIK_KEY": "@freepik_key",
    "FREEPIK_EDIT": "@freepik_edit",
    "NOTION_KEY": "@notion_key",
    "NOTION_DB": "@notion_db"
  }
}