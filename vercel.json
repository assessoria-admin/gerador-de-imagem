{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/generate/([^/]+)", "dest": "/api/generate/[taskId]" },
    { "src": "/api/notion/search",    "dest": "/api/notion/search" },
    { "src": "/api/proxy-image",      "dest": "/api/proxy-image" },
    { "src": "/api/generate",         "dest": "/api/generate" },
    { "src": "/app",                  "dest": "/app.html" },
    { "src": "/fonts/(.*)",           "dest": "/fonts/$1" },
    { "src": "/",                     "dest": "/index.html" }
  ]
}
